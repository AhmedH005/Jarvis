{
  "name": "jarvis",
  "version": "0.1.0",
  "description": "JARVIS - AI Interface for OpenClaw",
  "main": "dist-electron/main.js",
  "author": "ahmedh005",
  "private": true,
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE NODE_ENV=development electron-vite dev",
    "build": "electron-vite build",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "verify:core": "node scripts/verify-core.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.3.0",
    "ws": "^8.19.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^31.0.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  }
}
