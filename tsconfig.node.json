{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2022",
    "outDir": "dist-electron",
    "paths": {
      "@/*": ["./src/*"],
      "@electron/*": ["./electron/*"]
    }
  },
  "include": [
    "electron/**/*",
    "src/shared/builder-bridge.ts",
    "src/shared/planner-bridge.ts",
    "src/shared/phone-bridge.ts",
    "src/shared/gmail-bridge.ts",
    "src/shared/gcal-bridge.ts",
    "src/shared/operational-safety.ts",
    "src/shared/runtime-bridge.ts",
    "src/types/index.ts",
    "electron.vite.config.ts"
  ]
}
